# Osmo Backend Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================

# Set to 'true' when running in Docker Compose (uses service names instead of localhost)
DOCKER_MODE=false

# =============================================================================
# API KEYS (Required)
# =============================================================================

# Primary LLM provider
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternative LLM providers (optional)
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# SERVICE URLs (Auto-configured based on DOCKER_MODE)
# =============================================================================

# Connectors API (market data, indicators)
# Docker: http://connectors:8000/api/connectors
# Local: http://localhost:8000/api/connectors
CONNECTORS_API_URL=

# Analysis API (technical analysis)
# Docker: http://connectors:8000/api/connectors/analysis
# Local: http://localhost:8000/api/connectors/analysis
ANALYSIS_API_URL=

# Memory API (conversation history, learned patterns)
# Docker: http://mem0:8888
# Local: http://localhost:8888
MEM0_API_URL=

# Vector Database (Qdrant)
# Docker: http://qdrant:6333
# Local: http://localhost:6333
QDRANT_API_URL=

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Default exchange for order execution
EXECUTION_EXCHANGE=simulation

# Maximum position size in USD
MAX_NOTIONAL_USD=5000

# Maximum leverage allowed
MAX_LEVERAGE=50

# Enable TP/SL requirements (true/false)
ENABLE_TPSL=true

# Enable GP/GL requirements (true/false)
ENABLE_GPGL=true

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Default model for agent responses
DEFAULT_MODEL_ID=gpt-4o

# Reasoning effort (low, medium, high, extra_high)
REASONING_EFFORT=medium

# Tool profile (compact, full)
TOOL_PROFILE=full

# Enable memory features (true/false)
MEMORY_ENABLED=true

# Enable knowledge base (true/false)
KNOWLEDGE_ENABLED=true

# =============================================================================
# RELIABILITY MODES
# =============================================================================

# Reliability mode (strict, balanced, aggressive)
RELIABILITY_MODE=balanced

# Recovery mode (recover_then_continue, fail_fast)
RECOVERY_MODE=recover_then_continue

# Maximum tool actions per request (empty = unlimited)
MAX_TOOL_ACTIONS=

# Tool timeout in seconds
TOOL_TIMEOUT_SEC=8.0

# Model timeout in seconds
MODEL_TIMEOUT_SEC=120.0

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log to file (optional, leave empty for stdout only)
LOG_FILE=

# =============================================================================
# TRADINGVIEW CONFIGURATION
# =============================================================================

# TradingView command API URL
TRADINGVIEW_API_URL=http://localhost:3000

# TradingView command timeout
TRADINGVIEW_TIMEOUT_SEC=5.0

# Enable strict write verification (true/false)
STRICT_WRITE_VERIFICATION=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable web observation features (true/false)
WEB_OBSERVATION_ENABLED=true

# Web observation mode (quality, speed, budget)
WEB_OBSERVATION_MODE=quality

# Enable plan mode (AI-based planning, true/false)
PLAN_MODE=false

# Enable bootstrap prefetch (true/false)
BOOTSTRAP_PREFETCH=false

# Enable strict ReAct enforcement (true/false)
STRICT_REACT=true

# =============================================================================
# RATE LIMITING
# =============================================================================

# Requests per minute (0 = unlimited)
RATE_LIMIT_RPM=0

# Requests per hour (0 = unlimited)
RATE_LIMIT_RPH=0

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Enable response caching (true/false)
CACHE_ENABLED=true

# Cache TTL in seconds
CACHE_TTL_SEC=60

# Plan cache TTL in seconds
PLAN_CACHE_TTL_SEC=120

# =============================================================================
# SECURITY
# =============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=*

# API key for backend authentication (optional)
BACKEND_API_KEY=

# =============================================================================
# DOCKER COMPOSE EXAMPLE
# =============================================================================
# When running with Docker Compose, set:
# DOCKER_MODE=true
#
# Service URLs will automatically use:
# - connectors:8000
# - mem0:8888
# - qdrant:6333
#
# Example docker-compose.yml:
# version: '3.8'
# services:
#   backend:
#     build: .
#     env_file: .env
#     ports:
#       - "8000:8000"
#     depends_on:
#       - connectors
#       - mem0
#       - qdrant
#
#   connectors:
#     image: osmo-connectors:latest
#     ports:
#       - "8001:8000"
#
#   mem0:
#     image: mem0/mem0:latest
#     ports:
#       - "8889:8888"
#
#   qdrant:
#     image: qdrant/qdrant:latest
#     ports:
#       - "6334:6333"
#     volumes:
#       - qdrant_storage:/qdrant/storage
#
# volumes:
#   qdrant_storage:

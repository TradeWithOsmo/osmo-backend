# Osmo Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
DOCKER_MODE=false

# =============================================================================
# API KEYS
# =============================================================================
BASE_RPC_URL=<your_base_sepolia_rpc_url>
ARBITRUM_RPC_URL=<your_base_sepolia_rpc_url>
CHAINLINK_RPC_URL=<your_base_sepolia_rpc_url>
ARBITRUM_BACKUP_RPC_URL=https://base-sepolia-rpc.publicnode.com

OPENROUTER_API_KEY=
ALIBABA_API_KEY=<your_alibaba_dashscope_api_key>
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# SERVICE URLs
# =============================================================================
CONNECTORS_API_URL=http://localhost:8000/api/connectors
ANALYSIS_API_URL=http://localhost:8000/api/connectors/analysis
MEM0_API_URL=http://localhost:8888
QDRANT_API_URL=http://localhost:6333

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
EXECUTION_EXCHANGE=simulation
MAX_NOTIONAL_USD=5000
MAX_LEVERAGE=50
ENABLE_TPSL=true
ENABLE_GPGL=true

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
DEFAULT_MODEL_ID=alibaba/qwen-plus
REASONING_EFFORT=medium
TOOL_PROFILE=full
MEMORY_ENABLED=true
KNOWLEDGE_ENABLED=true

# =============================================================================
# RELIABILITY MODES
# =============================================================================
RELIABILITY_MODE=balanced
RECOVERY_MODE=recover_then_continue
MAX_TOOL_ACTIONS=8
TOOL_TIMEOUT_SEC=8.0
MODEL_TIMEOUT_SEC=120.0

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/backend.log

# =============================================================================
# TRADINGVIEW CONFIGURATION
# =============================================================================
TRADINGVIEW_API_URL=http://localhost:3000
TRADINGVIEW_TIMEOUT_SEC=5.0
STRICT_WRITE_VERIFICATION=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
WEB_OBSERVATION_ENABLED=true
WEB_OBSERVATION_MODE=quality
PLAN_MODE=false
BOOTSTRAP_PREFETCH=false
STRICT_REACT=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_RPM=0
RATE_LIMIT_RPH=0

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_ENABLED=true
CACHE_TTL_SEC=60
PLAN_CACHE_TTL_SEC=120

# =============================================================================
# SECURITY
# =============================================================================
CORS_ORIGINS=*
BACKEND_API_KEY=<change_me>

# =============================================================================
# NETWORK
# =============================================================================
NETWORK_MODE=testnet
NETWORK_NAME=base_sepolia
CHAIN_ID=84532
BLOCK_EXPLORER_URL=https://sepolia.basescan.org

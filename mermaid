flowchart TD
    subgraph INPUT["INPUT"]
        USER["USER PROMPT"]
        FE["FRONTEND"]
    end

    subgraph EVAL["EVALUATOR AGENT"]
        ORCH["ORCHESTRATOR"]
        GEN["GENERATOR"]
        EVALUATE["EVALUATOR"]
        OBS["OBSERVE"]
    end

    subgraph GATES["PERMISSION GATES"]
        GWRITE{"ENABLE WRITE?"}
        GEXEC{"ENABLE EXECUTION?"}
    end

    subgraph FTOOLS["FRONTEND TOOLS"]
        HINT["HINT/INDICATOR"]
        TF["TIMEFRAME"]
        ATTACH["ATTACHMENT"]
        PHOTO["PHOTO/DOC"]
        TVWRITE["TV WRITE/ADD/GET/NAV"]
        MKTORDER["MARKET ORDER"]
    end

    subgraph STYLES["AI STYLES"]
        SSTYLE{"STYLE TYPE?"}
        CONV["CONVERSATION"]
        TSTYLE["TRADING STYLE"]
        JESSE["JESSE LIVERMORE"]
        DARVAS["NICOLAS DARVAS"]
        OTHERS["OTHERS"]
    end

    subgraph BTOOLS["BACKEND TOOLS"]
        WEB["WEB SEARCH"]
        MEM["MEMORY"]
        TVAPI["TRADINGVIEW API"]
        ENABLE{"ENABLED?"}
    end

    subgraph CONNECTORS["DATA CONNECTORS"]
        HL["HYPERLIQUID"]
        OST["OSTIUM"]
        CHAIN["CHAINLINK"]
        DUNE["DUNE"]
    end

    subgraph KNOWLEDGE["KNOWLEDGE BASE"]
        QDRANT["QDRANT VECTOR DB"]
        EMBED["EMBEDDINGS"]
        KB["KNOWLEDGE DOCS"]
    end

    subgraph CONFIG["CONFIGURATION"]
        MAXCALL["MAX TOOLS CALL"]
        LIMIT["LIMIT CHAIN"]
    end

    subgraph MODELS["MODELS"]
        ROUTER["MODEL ROUTER"]
        OR["OPENROUTER"]
        GPT["GPT-4"]
        CLAUDE["CLAUDE"]
        OTHER["OTHERS"]
    end

    subgraph DOCKER["DOCKER SERVICES"]
        BACKEND["BACKEND API"]
        REDIS["REDIS CACHE"]
        POSTGRES["POSTGRESQL"]
        MEM0["MEM0 SERVICE"]
        INNGEST["INNGEST WORKER"]
    end

    subgraph OUTPUT["OUTPUT"]
        RESULT["RESULT"]
        PLAN["TRADING PLAN"]
    end

    USER --> FE --> ORCH
    ORCH --> GEN --> EVALUATE

    EVALUATE --> SSTYLE
    SSTYLE -->|CONVERSATION| CONV --> GEN
    SSTYLE -->|TRADING| TSTYLE
    TSTYLE --> JESSE & DARVAS & OTHERS
    JESSE & DARVAS & OTHERS --> GEN

    EVALUATE --> GWRITE & GEXEC
    GWRITE -->|YES| TVWRITE --> OBS
    GWRITE -->|NO| GEN
    GEXEC -->|YES| MKTORDER --> OBS
    GEXEC -->|NO| GEN

    EVALUATE --> HINT & TF
    HINT & TF --> ATTACH --> PHOTO

    EVALUATE --> ENABLE
    ENABLE -->|YES| WEB & MEM & TVAPI
    ENABLE -->|NO| GEN
    WEB & MEM & TVAPI --> OBS
    PHOTO --> OBS

    ORCH --> HL & OST & CHAIN & DUNE
    HL & OST & CHAIN & DUNE --> OBS

    MEM --> MEM0
    MEM0 --> QDRANT
    QDRANT --> EMBED --> KB
    KB --> ORCH

    OBS --> GEN

    ORCH --> MAXCALL --> LIMIT
    LIMIT --> GEN

    GEN --> ROUTER
    ROUTER --> OR & GPT & CLAUDE & OTHER
    OR & GPT & CLAUDE & OTHER --> RESULT

    BACKEND -.-> ORCH
    REDIS -.-> BACKEND
    POSTGRES -.-> BACKEND
    INNGEST -.-> BACKEND

    RESULT --> PLAN

    classDef main fill:#161b22,stroke:#30363d,color:#c9d1d9,stroke-width:1px;
    classDef group fill:transparent,stroke:#484f58,color:#8b949e,stroke-width:1px,stroke-dasharray: 5 5;
    classDef highlight fill:#1f6feb,stroke:#58a6ff,color:#ffffff,stroke-width:2px;

    class USER,FE,ORCH,GEN,EVALUATE,OBS,GWRITE,GEXEC,HINT,TF,ATTACH,PHOTO,TVWRITE,MKTORDER,SSTYLE,CONV,TSTYLE,JESSE,DARVAS,OTHERS,WEB,MEM,TVAPI,ENABLE,HL,OST,CHAIN,DUNE,QDRANT,EMBED,KB,MAXCALL,LIMIT,ROUTER,OR,GPT,CLAUDE,OTHER,BACKEND,REDIS,POSTGRES,MEM0,INNGEST,RESULT,PLAN main;
    class INPUT,EVAL,GATES,FTOOLS,STYLES,BTOOLS,CONNECTORS,KNOWLEDGE,CONFIG,MODELS,DOCKER,OUTPUT group;
    class ORCH highlight;

    linkStyle default stroke:#8b949e,stroke-width:1px;

LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=miniosecret
LANGFUSE_REDIS_AUTH=myredissecret

# Knowledge Base (Qdrant + Inngest + Agent)
QDRANT_ENABLED=true
QDRANT_KB_COLLECTION=osmo_knowledge_base_384
KB_EMBEDDING_PROVIDER=openrouter
KB_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
KB_EMBEDDING_DIMS=0

# Memory (mem0)
# Option A: run mem0 REST server from backend/mem0/server on port 8888
# If running inside Docker, use http://osmo-mem0:8000 (service DNS).
# If running on host, use http://localhost:8888 (port mapping).
MEM0_API_URL=http://localhost:8888
# Option B: enable in-process mem0 connector
MEM0_ENABLED=false

# Provider keys
OPENAI_API_KEY=
GOOGLE_API_KEY=AIzaSyAdkYGfZoKZAq-ExmyPmOCWqIHk6_T_ay4

# Database Configuration
SAVE_TO_DB=False
DATABASE_URL=postgresql://osmo_user:osmo_password@localhost:5432/osmo_db

# Hyperliquid Configuration
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Ostium Configuration
OSTIUM_API_URL=https://metadata-backend.ostium.io
OSTIUM_POLL_INTERVAL=2

# Application Settings
LOG_LEVEL=INFO
CORS_ORIGINS=*

# Privy Auth
PRIVY_APP_ID=your_privy_app_id
PRIVY_VERIFICATION_KEY=your_privy_verification_key

# Redis
REDIS_URL=redis://localhost:6379/0

# Dune Analytics Configuration
DUNE_API_KEY=your_dune_api_key
DUNE_QUERY_WHALE_TRADES=your_query_id

# Data Aggregator Settings
ENABLE_DATA_CACHING=True
CACHE_TTL_SECONDS=10

# Connector Settings (Data Sources)
# Chainlink Oracle
CHAINLINK_RPC_URL=https://arb1.arbitrum.io/rpc
CHAINLINK_BACKUP_RPC=https://arbitrum.llamarpc.com

# TradingView Settings
TRADINGVIEW_CACHE_TTL=60

# Web Search (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key

# Connector Global Settings
CONNECTOR_CACHE_TTL=10
CONNECTOR_RETRY_ATTEMPTS=3
CONNECTOR_TIMEOUT_SECONDS=30

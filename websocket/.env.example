NVIDIA_MAX_COMPLETION_TOKENS=16384
OPENAI_API_KEY=
GEMINI_API_KEY=<your_gemini_api_key>
GOOGLE_API_KEY=<your_google_api_key>
ALPHA_VANTAGE_API_KEY=<your_alpha_vantage_api_key>

TRADINGVIEW_CACHE_TTL=0

# Connector settings
CONNECTOR_CACHE_TTL=10
CONNECTOR_RETRY_ATTEMPTS=3
CONNECTOR_TIMEOUT_SECONDS=30

# Memory (Qdrant + Mem0)
MEM0_ENABLED=true
QDRANT_ENABLED=true
QDRANT_HOST=osmo-qdrant
QDRANT_KB_COLLECTION=osmo_knowledge_base_384
KB_EMBEDDING_PROVIDER=local
KB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
KB_EMBEDDING_DIMS=384
MEM0_API_URL=http://osmo-mem0:8000
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=openai/gpt-4o-mini
MEM0_EMBEDDER_PROVIDER=gemini
MEM0_EMBEDDER_MODEL=models/text-embedding-004
MEM0_EMBEDDING_DIMS=768

# Exchange settings
HYPERLIQUID_TESTNET=false
HYPERLIQUID_RPC_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
OSTIUM_RPC_URL=<your_arbitrum_sepolia_rpc_url>
OSTIUM_TESTNET=true
OSTIUM_API_URL=https://metadata-backend.ostium.io
OSTIUM_POLL_INTERVAL=2
OSTIUM_SUBGRAPH_URL=https://subgraph.satsuma-prod.com/391a61815d32/ostium/ost-sep-final/api

# Database
DATABASE_URL=postgresql+asyncpg://osmo_user:osmo_password@localhost:5432/osmo_db
REDIS_URL=redis://localhost:6379

# Auth
PRIVY_APP_ID=<your_privy_app_id>
PRIVY_VERIFICATION_KEY=<your_privy_verification_key>

# Network
BASE_RPC_URL=<your_base_sepolia_rpc_url>
NETWORK_MODE=testnet
NETWORK_NAME=base_sepolia
CHAIN_ID=84532
BLOCK_EXPLORER_URL=https://sepolia.basescan.org

# On-chain signing key (session key — NOT your main wallet private key)
TREASURY_PRIVATE_KEY=<your_session_key_private_key>
AI_BILLING_SIGNER_PRIVATE_KEY=<your_session_key_private_key>
PRIVATE_KEY_SECONDARY=
PRIVATE_KEY_TERTIARY=
AI_BILLING_ONCHAIN_ENABLED=false
AI_BILLING_RECEIPT_TIMEOUT_SECONDS=90
AI_BILLING_REQUIRE_OPERATOR_ROLE=true

# Contract Addresses — copy from osmo-contracts/.env after deployment
OSMO_CORE_ADDRESS=
TRADING_VAULT_ADDRESS=
RISK_MANAGER_ADDRESS=
POSITION_MANAGER_ADDRESS=
ORDER_ROUTER_ADDRESS=
SESSION_KEY_MANAGER_ADDRESS=
AI_VAULT_ADDRESS=
USDC_ADDRESS=
FAUCET_ADDRESS=
PRICE_FEED_ADDRESS=
SYMBOL_REGISTRY_ADDRESS=
OSTIUM_ADAPTER_ADDRESS=
FEE_MANAGER_ADDRESS=
CUSTOM_MARKET_DATA_FEED_ADDRESS=
ARENA_SECURITY_ADDRESS=
ARENA_POINTS_ADDRESS=
ARENA_CHOOSE_SIDE_ADDRESS=
BUILDER_ADDRESS=
EXPECTED_KICKBACK_BPS=25

# App settings
SAVE_TO_DB=False
WS_IN_MEMORY_ONLY=True
FORCE_EXECUTION_MODE=simulation
RATE_LIMIT_PER_MINUTE=60
ALLOW_TESTNET_ADDRESSES=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
SECONDARY_HISTORY_ENABLED=False
SECONDARY_HISTORY_PREWARM=False
SESSION_HISTORY_DAYS=1
SECONDARY_CRYPTO_ONLY=true
SECONDARY_NON_CRYPTO_PROVIDER=yahoo
SECONDARY_DISABLE_COMMODITIES=true

# Ingest
INGEST_MIN_CONFIDENCE=0.8
INGEST_ALLOWED_TYPES=article
INGEST_UPSERT_BATCH_SIZE=100
INGEST_DEDUP_DB_PATH=/data/.ingest_dedup.sqlite3

# Langfuse (optional observability)
LANGFUSE_ENABLED=false
LANGFUSE_LLM_PROVIDER=openrouter
LANGFUSE_LLM_BASE_URL=https://openrouter.ai/api/v1
LANGFUSE_LLM_CONNECTION_TEMPLATE=openrouter:{model}

# Uptime Kuma
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=<change_me>
UPTIME_STATUS_PAGE_SLUG=osmo-status
UPTIME_STATUS_PAGE_TITLE=Osmo Status

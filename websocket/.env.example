CHAINLINK_BACKUP_RPC=https://base-sepolia-rpc.publicnode.com
ARBITRUM_RPC=<your_base_sepolia_rpc_url>
ARBITRUM_RPC_URL=<your_base_sepolia_rpc_url>
ARBITRUM_BACKUP_RPC_URL=https://base-sepolia-rpc.publicnode.com

# LLM Providers
OPENROUTER_API_KEY=
ALIBABA_API_KEY=<your_alibaba_dashscope_api_key>
DASHSCOPE_API_KEY=<your_alibaba_dashscope_api_key>
GROQ_API_KEY=<your_groq_api_key>
GROQ_SECONDARY_API_KEY=
GROQ_TERTIARY_API_KEY=
GROQ_QUATERNARY_API_KEY=
NVIDIA_API_KEY=<your_nvidia_nim_api_key>
NVIDIA_SECONDARY_API_KEY=
NIM_API_KEY=
